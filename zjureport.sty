\tl_gset:Nn \g_zju_cover_name_tl {本科实验报告}
\tl_gset:Nn \g_zju_cover_subtitle_tl {Undergraduate Lab Report}
\tl_gset:Nn \g_zju_title_tl {实验报告标题}
\tl_gset:Nn \g_zju_course_tl {课程名称}
\tl_gset:Nn \g_zju_semester_tl {}
\tl_gset:Nn \g_zju_author_tl {姓名}
\tl_gset:Nn \g_zju_school_id_tl {学号}
\tl_gset:Nn \g_zju_college_tl {学院}
\tl_gset:Nn \g_zju_major_tl {专业}
\tl_gset:Nn \g_zju_teacher_tl {指导教师}
\tl_gset:Nn \g_zju_place_tl {实验地点}
\tl_gset:Nn \g_zju_date_tl {\today}
\tl_gset:Nn \g_zju_project_name_tl {实验名称}
\tl_gset:Nn \g_zju_experiment_type_tl {设计型实验}
\tl_gset:Nn \g_zju_groupmate_tl {}
\tl_gset:Nn \g_zju_grade_tl {}

\keys_define:nn { zjureport }
  {
    cover-name .tl_gset:N = \g_zju_cover_name_tl,
    cover-subtitle .tl_gset:N = \g_zju_cover_subtitle_tl,
    title .tl_gset:N = \g_zju_title_tl,
    course .tl_gset:N = \g_zju_course_tl,
    semester .tl_gset:N = \g_zju_semester_tl,
    author .tl_gset:N = \g_zju_author_tl,
    school-id .tl_gset:N = \g_zju_school_id_tl,
    college .tl_gset:N = \g_zju_college_tl,
    major .tl_gset:N = \g_zju_major_tl,
    teacher .tl_gset:N = \g_zju_teacher_tl,
    place .tl_gset:N = \g_zju_place_tl,
    date .tl_gset:N = \g_zju_date_tl,
    project-name .tl_gset:N = \g_zju_project_name_tl,
    experiment-type .tl_gset:N = \g_zju_experiment_type_tl,
    groupmate .tl_gset:N = \g_zju_groupmate_tl,
    grade .tl_gset:N = \g_zju_grade_tl,
  }

\NewDocumentCommand{\zjusetup}{m}{\keys_set:nn { zjureport } {#1}}
\NewDocumentCommand{\zjumetadata}{m}{\zjusetup{#1}}
\NewDocumentCommand{\zjuval}{m}{\tl_use:c { g_zju_#1_tl }}
\ExplSyntaxOff

% Direct port of Typst binding_line_background().
\newif\ifzjubindingline
\zjubindinglinefalse
\newcommand{\enablebindingline}{\zjubindinglinetrue}
\newcommand{\disablebindingline}{\zjubindinglinefalse}
\newcommand{\zjubindingline}{%
  \ifzjubindingline
    \begin{tikzpicture}[remember picture,overlay]
      \draw[black!70,dashed,line width=1pt]
        ([xshift=1.15cm,yshift=-2.5cm]current page.north west)
        -- ([xshift=1.15cm,yshift={-(14.35cm - 1.75em - 0.3cm)}]current page.north west);
      \node[
        anchor=north,
        align=center,
        text=black!70,
        font=\bfseries\fontsize{14pt}{16pt}\selectfont,
        inner sep=0pt
      ] at ([xshift=1.15cm,yshift={-(14.65cm - 1.75em)}]current page.north west)
        {装\\[0.2em]订\\[0.2em]线};
      \draw[black!70,dashed,line width=1pt]
        ([xshift=1.15cm,yshift={-(14.35cm + 1.75em + 1.8cm)}]current page.north west)
        -- ([xshift=1.15cm,yshift={-(28.7cm)}]current page.north west);
    \end{tikzpicture}%
  \fi
}
\AddToShipoutPictureBG{\zjubindingline}

