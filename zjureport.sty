\NewDocumentCommand{\zjuunderline}{O{4cm}m}{\underline{\makebox[#1][c]{#2}}}

\newcommand{\zjucover}{
  \thispagestyle{empty}
  \begin{center}
    \vspace*{\fill}
    \includegraphics[width=\textwidth]{ZJU-Banner2.png}

    \vspace{0.5cm}
    {\heiti\fontsize{26pt}{32pt}\selectfont \zjuval{cover_name}\par}
    \vspace{0.5cm}
    {\fontsize{17pt}{22pt}\selectfont \zjuval{cover_subtitle}\par}

    \vspace*{\fill}
    \begingroup
    \fontsize{14.5pt}{22pt}\selectfont
    \renewcommand{\arraystretch}{1.45}
    \begin{tabular}{@{}>{\centering\arraybackslash}p{6.5em}>{\centering\arraybackslash}p{8cm}@{}}
      课程名称： & \zjuunderline[8cm]{\zjuval{course}}\\
      实验名称： & \zjuunderline[8cm]{\zjuval{project_name}}\\
      姓\quad\quad 名： & \zjuunderline[8cm]{\zjuval{author}}\\
      学\quad\quad 号： & \zjuunderline[8cm]{\zjuval{school_id}}\\
      学\quad\quad 院： & \zjuunderline[8cm]{\zjuval{college}}\\
      专\quad\quad 业： & \zjuunderline[8cm]{\zjuval{major}}\\
      实验地点： & \zjuunderline[8cm]{\zjuval{place}}\\
      指导教师： & \zjuunderline[8cm]{\zjuval{teacher}}\\
      报告日期： & \zjuunderline[8cm]{\zjuval{date}}
    \end{tabular}
    \endgroup

    \vspace*{\fill}
  \end{center}
  \clearpage
}
\newcommand{\cover}{\zjucover}

\newcommand{\zjulabheader}{
  \begingroup
  \fontsize{9.5pt}{12pt}\selectfont
  \setlength{\tabcolsep}{0pt}
  \renewcommand{\arraystretch}{1.15}
  \begin{center}
    \begin{tabularx}{\textwidth}{@{}X@{\hfill}p{5.5cm}@{}}
      \centering\includegraphics[width=\linewidth]{head.jpg} &
      \centering
      \begin{tabular}{@{}p{1.5cm}p{4cm}@{}}
        专业： & \zjuunderline[4cm]{\zjuval{major}}\\
        姓名： & \zjuunderline[4cm]{\zjuval{author}}\\
        学号： & \zjuunderline[4cm]{\zjuval{school_id}}\\
        日期： & \zjuunderline[4cm]{\zjuval{date}}\\
        地点： & \zjuunderline[4cm]{\zjuval{place}}
      \end{tabular}
    \end{tabularx}

    \vspace{0.25em}
    \begin{tabular}{@{}>{\raggedright\arraybackslash}p{0.12\textwidth}
                    >{\centering\arraybackslash}p{0.20\textwidth}
                    >{\raggedright\arraybackslash}p{0.12\textwidth}
                    >{\centering\arraybackslash}p{0.25\textwidth}
                    >{\raggedright\arraybackslash}p{0.16\textwidth}
                    >{\centering\arraybackslash}p{0.14\textwidth}@{}}
      课程名称： & \zjuval{course} &
      指导老师： & \zjuval{teacher} &
      成\quad\quad 绩： & \zjuval{grade}\\[-0.15em]
      \cline{2-2}\cline{4-4}\cline{6-6}
      实验名称： & \zjuval{project_name} &
      实验类型： & \zjuval{experiment_type} &
      同组学生姓名： & \zjuval{groupmate}\\[-0.15em]
      \cline{2-2}\cline{4-4}\cline{6-6}
    \end{tabular}
  \end{center}
  \endgroup
  \vspace{1em}
}

\NewDocumentCommand{\ISEEHeader}{O{}}{
  \zjusetup{#1}
  \enablebindingline
  \zjulabheader
}

\newtcolorbox{zjubox}[2][]{
  enhanced,
  breakable,
  colback=#2!6,
  colframe=#2!65!black,
  boxrule=0.6pt,
  arc=1mm,
  left=1em,
  right=1em,
  top=0.75em,
  bottom=0.75em,
  #1
}

\NewDocumentCommand{\tbox}{m}{\begin{zjubox}{gray}#1\end{zjubox}}
\NewDocumentCommand{\notebox}{m}{\begin{zjubox}[title=Note]{blue}#1\end{zjubox}}
\NewDocumentCommand{\importantbox}{m}{\begin{zjubox}[title=Important]{green}#1\end{zjubox}}
\NewDocumentCommand{\warningbox}{m}{\begin{zjubox}[title=Warning]{orange}#1\end{zjubox}}
\NewDocumentCommand{\questionbox}{m}{\begin{zjubox}[title=Question]{purple}#1\end{zjubox}}

\lstdefinestyle{zjucode}{
  basicstyle=\ttfamily\small,
  keywordstyle=\color{blue!70!black}\bfseries,
  commentstyle=\color{gray!80!black},
  stringstyle=\color{red!60!black},
  numbers=left,
  numberstyle=\tiny\color{gray},
  stepnumber=1,
  numbersep=0.8em,
  breaklines=true,
  columns=fullflexible,
  frame=single,
  rulecolor=\color{gray!45},
  backgroundcolor=\color{gray!6},
  tabsize=2
}
\lstset{style=zjucode}
\lstnewenvironment{codeblock}[1][]{\lstset{style=zjucode,#1}}{}
\NewDocumentCommand{\codex}{O{}m}{\lstinputlisting[style=zjucode,#1]{#2}}
\NewDocumentCommand{\mycode}{O{}m}{\lstinputlisting[style=zjucode,#1]{#2}}

\newcommand{\reference}{
  \nocite{0Isaac}
  \bibliographystyle{unsrt}
  \bibliography{reference}
}
