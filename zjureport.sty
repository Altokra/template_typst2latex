\ExplSyntaxOn
\tl_new:N \g_zju_cover_name_tl
\tl_new:N \g_zju_cover_subtitle_tl
\tl_new:N \g_zju_title_tl
\tl_new:N \g_zju_course_tl
\tl_new:N \g_zju_semester_tl
\tl_new:N \g_zju_author_tl
\tl_new:N \g_zju_school_id_tl
\tl_new:N \g_zju_college_tl
\tl_new:N \g_zju_major_tl
\tl_new:N \g_zju_teacher_tl
\tl_new:N \g_zju_place_tl
\tl_new:N \g_zju_date_tl
\tl_new:N \g_zju_project_name_tl
\tl_new:N \g_zju_experiment_type_tl
